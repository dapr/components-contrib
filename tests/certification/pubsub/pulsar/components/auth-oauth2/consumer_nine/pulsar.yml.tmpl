apiVersion: dapr.io/v1alpha1
kind: Component
metadata:
  name: messagebus
spec:
  type: pubsub.pulsar
  version: v1
  metadata:
  - name: host
    value: "127.0.0.1:6651"
  - name: consumerID
    value: certification9
  - name: redeliveryDelay
    value: 200ms
  - name: certification-pubsub-topic-avro.avroschema
    value: "{\"type\":\"record\",\"name\":\"Student\",\"namespace\":\"test\",\"fields\":[{\"name\":\"studentId\",\"type\":\"int\"},{\"name\":\"studentName\",\"type\":\"string\"}]}"
  - name: oauth2TokenURL
    value: https://localhost:8085/issuer1/token
  - name: oauth2ClientID
    value: foo
  - name: oauth2ClientSecret
    value: bar
  - name: oauth2Scopes
    value: openid
  - name: oauth2Audiences
    value: pulsar
  - name: oauth2TokenCAPEM
    value: "{{ .OAuth2CAPEM }}"
